# ============================================================
# PromptShield Enterprise - Docker Compose Environment
# Copy this file to .env in the same directory.
# ============================================================

# PostgreSQL
POSTGRES_USER=promptshield
POSTGRES_PASSWORD=changeme
POSTGRES_DB=promptshield
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Enterprise API
ENTERPRISE_API_PORT=8000
PROMPTSHIELD_API_KEY=ps-dev-key-change-me
PROMPTSHIELD_ADMIN_KEY=ps-admin-key-change-me
SECRET_KEY=change-me-to-a-secure-random-key-at-least-32-chars
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_WORKERS=4
STORE_RAW_PROMPTS=false
ALLOWED_ORIGINS=http://localhost:3000

# Provider Keys (for proxy mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Enterprise UI
ENTERPRISE_UI_PORT=3000
VITE_API_KEY=ps-dev-key-change-me
VITE_ADMIN_KEY=ps-admin-key-change-me

# Prometheus
PROMETHEUS_PORT=9090
