# ============================================================
# PromptShield Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Enterprise API - Core Settings
# ------------------------------------------------------------
# PostgreSQL connection URL
DATABASE_URL=postgresql+asyncpg://promptshield:changeme@localhost:5432/promptshield

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# API key header name (default: X-API-Key)
API_KEY_HEADER=X-API-Key

# Master API key for enterprise API access
PROMPTSHIELD_API_KEY=ps-dev-key-change-me

# Admin API key (used for admin-only endpoints)
PROMPTSHIELD_ADMIN_KEY=ps-admin-key-change-me

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Application environment: development | staging | production
ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum number of worker processes (default: 4)
MAX_WORKERS=4

# ------------------------------------------------------------
# Enterprise API - Privacy
# ------------------------------------------------------------
# Whether to store raw prompt text in the database (default: false)
# Set to true only if required for audit and you have proper data controls
STORE_RAW_PROMPTS=false

# Path to custom config directory (optional, overrides defaults)
# CONFIG_DIR=/etc/promptshield/config

# ------------------------------------------------------------
# Provider API Keys (for proxy mode)
# ------------------------------------------------------------
# OpenAI API key
OPENAI_API_KEY=sk-...

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Ollama base URL (for local model routing)
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------
# PromptShield Lite - CLI Settings
# ------------------------------------------------------------
# Enterprise API URL (optional, for Lite in connected mode)
# PROMPTSHIELD_ENTERPRISE_URL=http://localhost:8000

# Override config directory for Lite
# PROMPTSHIELD_CONFIG_DIR=~/.config/promptshield

# ------------------------------------------------------------
# Enterprise UI
# ------------------------------------------------------------
# API base URL for the UI to connect to
VITE_API_BASE_URL=http://localhost:8000/api

# UI API key (used in development - in production use proper auth)
VITE_API_KEY=ps-dev-key-change-me

# ------------------------------------------------------------
# Docker Compose Settings
# ------------------------------------------------------------
# PostgreSQL credentials
POSTGRES_USER=promptshield
POSTGRES_PASSWORD=changeme
POSTGRES_DB=promptshield

# Redis password (leave empty for no auth in dev)
REDIS_PASSWORD=

# Exposed ports
ENTERPRISE_API_PORT=8000
ENTERPRISE_UI_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
